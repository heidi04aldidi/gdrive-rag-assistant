# ─────────────────────────────────────────────────────────────────────────────
# Google Drive
# ─────────────────────────────────────────────────────────────────────────────
# Path to your OAuth2 client_secret JSON or service-account key JSON
GDRIVE_CREDENTIALS_FILE=credentials.json

# (OAuth only) Where to cache the access/refresh token
GDRIVE_TOKEN_FILE=token.json

# (Optional) Restrict sync to a specific Drive folder by ID
# Leave blank to sync all accessible files
GDRIVE_FOLDER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Embedding
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# ─────────────────────────────────────────────────────────────────────────────
# Chunking
# ─────────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─────────────────────────────────────────────────────────────────────────────
# Retrieval
# ─────────────────────────────────────────────────────────────────────────────
TOP_K=5

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider — choose "openai" or "anthropic"
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ─────────────────────────────────────────────────────────────────────────────
# API Server
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
